<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<section id="vendors" class="vendor-section">
    <div class="vendor-container">
        
        <!-- 模块头部区域 -->
        <div class="vendor-heading">
            <h3 class="vendor-section-title brand-font">Featured Vendors</h3>
            <div class="vendor-heading-line"></div>
            <p class="vendor-section-subtitle">Discover the masterminds behind the extraordinary tastes.</p>
        </div>

        <!-- 商家网格容器 -->
        <div class="vendor-grid">
            
            <!-- 商家卡片 1 -->
            <div class="vendor-card">
                <div class="vendor-img-wrap">
                    <img src="assets/images/vendor/grill.png" class="vendor-avatar" alt="The Grill Master">
                </div>
                <div class="vendor-name-wrap">
                    <h4 class="vendor-name">The Grill Master</h4>
                </div>
                <div class="vendor-tag-wrap">
                    <p class="vendor-tag">BBQ & Smoked Meats</p>
                </div>
                <div class="vendor-desc-wrap">
                    <p class="vendor-desc">Bringing the authentic Texas smokehouse experience to your plate.</p>
                </div>
            </div>
		
            <!-- 商家卡片 2 -->
            <div class="vendor-card">
                <div class="vendor-img-wrap">
                    <img src="assets/images/vendor/sushi.jpg" class="vendor-avatar" alt="Sushi Zen">
                </div>
                <div class="vendor-name-wrap">
                    <h4 class="vendor-name">Sushi Zen</h4>
                </div>
                <div class="vendor-tag-wrap">
                    <p class="vendor-tag">Japanese Specialty</p>
                </div>
                <div class="vendor-desc-wrap">
                    <p class="vendor-desc">Fresh, handcrafted sushi made with premium grade-A ingredients.</p>
                </div>
            </div>
		
            <!-- 商家卡片 3 -->
            <div class="vendor-card">
                <div class="vendor-img-wrap">
                    <img src="assets/images/vendor/pasta.jpg" class="vendor-avatar" alt="Pasta Paradiso">
                </div>
                <div class="vendor-name-wrap">
                    <h4 class="vendor-name">Pasta Paradiso</h4>
                </div>
                <div class="vendor-tag-wrap">
                    <p class="vendor-tag">Italian Classics</p>
                </div>
                <div class="vendor-desc-wrap">
                    <p class="vendor-desc">Homemade pasta sauces following traditional family recipes.</p>
                </div>
            </div>
            
		</div>
    </div>
</section>